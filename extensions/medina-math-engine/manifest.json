{
  "manifest_version": 3,
  "name": "Medina Math Engine",
  "version": "1.0.0",
  "description": "MOTOR MATHEMATICAE — Math database terminal access. Sovereign Medina browser extension. φ=1.618033988749895",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Medina Math Engine"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}