{
  "name": "@medina/platform",
  "version": "1.0.0",
  "private": true,
  "description": "MEDINA — Sovereign Memory-Operating Intelligence Platform. Root workspace for all substrates.",
  "author": "Alfredo Medina Hernandez | Medina Tech | Dallas, TX",
  "license": "ISIL-1.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "validate": "bash scripts/validate.sh",
    "validate:canister": "bash scripts/validate.sh canister",
    "validate:extensions": "bash scripts/validate.sh extensions",
    "validate:packages": "bash scripts/validate.sh packages",
    "validate:cli": "bash scripts/validate.sh cli",
    "validate:rust": "bash scripts/validate.sh rust",
    "validate:dist": "bash scripts/validate.sh dist",
    "build:extensions": "bash scripts/build-extensions.sh",
    "build:bundle": "node dist/bundle.js",
    "build:rust": "cd rust/medina_crypto && cargo build --release",
    "deploy:canister": "bash scripts/deploy-canister.sh",
    "deploy:canister:local": "bash scripts/deploy-canister.sh local",
    "deploy:canister:ic": "bash scripts/deploy-canister.sh ic",
    "publish:sdk": "bash scripts/publish-sdk.sh",
    "publish:sdk:all": "bash scripts/publish-sdk.sh all",
    "dev": "bash scripts/dev.sh",
    "dev:serve": "bash scripts/dev.sh serve",
    "dev:cli": "cd organism-cli && node src/index.js",
    "dev:workers": "cd organism-cli && node src/index.js workers",
    "install:local": "bash dist/install.sh",
    "status": "cd organism-cli && node src/index.js status",
    "clean": "rm -rf build/ node_modules/.cache"
  },
  "workspaces": [
    "packages/*",
    "organism-cli"
  ]
}
