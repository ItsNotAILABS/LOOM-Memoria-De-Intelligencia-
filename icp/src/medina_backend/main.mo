    ) : async () {
        let currentBeat = Heartbeat.currentBeat(heartbeatState);
        let heartsStatus = ThreeHeartsEncryption.status(threeHeartsState);
        let coherence = heartsStatus.coherence;
        
        ignore AnimaChainEncryption.extendChain(
            animaChainState,
            animaHash,
            currentBeat,
            doctrineAlignment,
            coherence
        );
    };
    
