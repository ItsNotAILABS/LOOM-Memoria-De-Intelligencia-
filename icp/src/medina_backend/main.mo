        protocols: [Text]; sdkBindings: [Text]; organismLinks: [Text];
        isAI: Bool; isAGI: Bool; isAlwaysOn: Bool;
    } {
        switch (AutoGenerateCallsEngine.getWorkerById(id)) {
            case null { null };
            case (?w) {
                ?{ id = w.id; name = w.name; latinName = w.latinName; latinMotto = w.latinMotto;
                   domain = w.domain; callsGenerated = w.callsGenerated; aiRole = w.aiRole;
                   protocols = w.protocols; sdkBindings = w.sdkBindings;
                   organismLinks = w.organismLinks;
                   isAI = w.isAI; isAGI = w.isAGI; isAlwaysOn = w.isAlwaysOn }
            };
        }
    };

    /// Get the full routing table across all workers
    public query func getAutoGenerateRoutes() : async [{
        id: Text; name: Text; latinName: Text; source: Text;
        targetModule: Text; endpoint: Text; latency_ms: Float;
        isAlwaysOn: Bool; phi_weighted: Bool;
    }] {
        Array.map<AutoGenerateCallsEngine.Route, {
            id: Text; name: Text; latinName: Text; source: Text;
            targetModule: Text; endpoint: Text; latency_ms: Float;
            isAlwaysOn: Bool; phi_weighted: Bool;
        }>(AutoGenerateCallsEngine.getAllRoutes(), func(r) {
            { id = r.id; name = r.name; latinName = r.latinName; source = r.source;
              targetModule = r.targetModule; endpoint = r.endpoint;
              latency_ms = r.latency_ms; isAlwaysOn = r.isAlwaysOn;
              phi_weighted = r.phi_weighted }
        })
    };

