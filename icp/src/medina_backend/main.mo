    /// Scan all files in a specific architecture layer
    /// layerName: "backend" | "frontend" | "novaovo" | "medina" | "release" | "doctrine"
    public query func scanArchitectureLayer(layerName: Text) : async [{
        fileName: Text;
        path: Text;
        fileType: Text;
        latinName: Text;
        latinMotto: Text;
        purpose: Text;
        isAlwaysOn: Bool;
        frequency_Hz: Float;
    }] {
        let layer : ArchitectureScanner.ArchLayer = switch (layerName) {
            case "frontend"  { #Frontend };
            case "novaovo"   { #NovaOvo };
            case "medina"    { #Medina };
            case "release"   { #Release };
            case "doctrine"  { #Doctrine };
            case _           { #Backend };   // default to backend
        };
        let files = ArchitectureScanner.scanLayer(layer);
        Array.map<ArchitectureScanner.ArchFile, {
            fileName: Text;
            path: Text;
            fileType: Text;
            latinName: Text;
            latinMotto: Text;
            purpose: Text;
            isAlwaysOn: Bool;
            frequency_Hz: Float;
        }>(files, func(f) {
            {
                fileName = f.fileName;
                path = f.path;
                fileType = f.fileType;
                latinName = f.latinName;
                latinMotto = f.latinMotto;
                purpose = f.purpose;
                isAlwaysOn = f.isAlwaysOn;
                frequency_Hz = f.frequency_Hz;
            }
        })
    };

    /// SYNTHESIZER: Produce the full architecture synthesis text
    public query func synthesizeArchitecture() : async Text {
        ArchitectureScanner.synthesize()
    };

    /// COLLECTOR: Get all callables from all registered files across all layers
    public query func collectAllArchitectureCallables() : async [{
        fileName: Text;
        layer: Text;
        latinName: Text;
        callable: Text;
    }] {
        let entries = ArchitectureScanner.collectAllCallables();
        Array.map<ArchitectureScanner.FunctionEntry, {
            fileName: Text;
            layer: Text;
            latinName: Text;
            callable: Text;
        }>(entries, func(e) {
            { fileName = e.fileName; layer = e.layer; latinName = e.latinName; callable = e.callable }
        })
    };

    /// Get the always-on living backbone — all always-on files
    public query func getLivingBackbone() : async [{
        fileName: Text;
        layer: Text;
        latinName: Text;
        latinMotto: Text;
        frequency_Hz: Float;
    }] {
        let files = ArchitectureScanner.getLivingBackbone();
        Array.map<ArchitectureScanner.ArchFile, {
            fileName: Text;
            layer: Text;
            latinName: Text;
            latinMotto: Text;
            frequency_Hz: Float;
        }>(files, func(f) {
            {
                fileName = f.fileName;
                layer = ArchitectureScanner.layerToLatin(f.layer);
                latinName = f.latinName;
                latinMotto = f.latinMotto;
                frequency_Hz = f.frequency_Hz;
            }
        })
    };

