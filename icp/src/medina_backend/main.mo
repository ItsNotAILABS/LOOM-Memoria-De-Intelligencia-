    /// Execute a command (main entry point for user interaction)
    public shared(msg) func execute(commandText: Text) : async Types.CommandResult {
        // THE TERMINAL IS AN ORGAN — Route through intelligent terminal
        // Parse command through terminal intelligence
        let session_id = Principal.toText(msg.caller);
        let cmd = IntelligentTerminal.parseCommand(terminalState, commandText, session_id);
        
        // Execute through organism intelligence
        let response = IntelligentTerminal.execute(terminalState, cmd);
        
        // Sync terminal heartbeat with organism heartbeat
        terminalState.current_heartbeat := Heartbeat.currentBeat(heartbeatState);
        
        // Return structured result
        {
            success = response.success;
            output = response.output # "\n\n💓 Heartbeat: " # Nat.toText(response.organism_status.heartbeat) # 
                     " | Coherence: " # Float.toText(response.organism_status.coherence) #
                     "\n🔮 ANIMA: " # response.anima_hash;
            error = if (response.success) { null } else { ?"Organism processing failed" };
        }
    };
    
    /// INTELLIGENT TERMINAL DIRECT ACCESS
    /// For Founder: Full terminal interface with suggestions
    public shared(msg) func terminalExecute(commandText: Text) : async IntelligentTerminal.TerminalResponse {
        let session_id = Principal.toText(msg.caller);
        let cmd = IntelligentTerminal.parseCommand(terminalState, commandText, session_id);
        
        // Sync heartbeat before execution
        terminalState.current_heartbeat := Heartbeat.currentBeat(heartbeatState);
        terminalState.organism_coherence := ThreeHeartsEngine.globalCoherence(threeHeartsState);
        
        // Execute through organism intelligence
        IntelligentTerminal.execute(terminalState, cmd)
    };
    
