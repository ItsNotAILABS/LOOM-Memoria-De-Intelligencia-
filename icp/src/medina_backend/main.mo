    public query func getSovereignTokens() : async [{
        id: Text; name: Text; generation: Nat;
        phase: Text; coherence: Float; energy: Float;
        evolution_count: Nat; maturity: Float;
        split_count: Nat; merge_count: Nat;
        attestation_count: Nat;
        cpl_contract_id: Text; cogpro_state: Text; sl_law_id: Text;
    }] {
        Array.map<SovereignTokenTT012.SovereignToken, {
            id: Text; name: Text; generation: Nat;
            phase: Text; coherence: Float; energy: Float;
            evolution_count: Nat; maturity: Float;
            split_count: Nat; merge_count: Nat;
            attestation_count: Nat;
            cpl_contract_id: Text; cogpro_state: Text; sl_law_id: Text;
        }>(SovereignTokenTT012.ALL_TOKENS, func(t) {
            { id = t.id; name = t.name; generation = t.generation;
              phase = SovereignTokenTT012.phaseToText(t.phase);
              coherence = t.coherence; energy = t.energy;
              evolution_count = t.evolution_count; maturity = t.maturity;
              split_count = t.split_count; merge_count = t.merge_count;
              attestation_count = t.attestation_count;
              cpl_contract_id = t.cpl_contract_id;
              cogpro_state = t.cogpro_state;
              sl_law_id = t.sl_law_id }
        })
    };

    /// Get a sovereign token by ID
    public query func getSovereignTokenById(id: Text) : async ?{
        id: Text; name: Text; generation: Nat;
        phase: Text; coherence: Float; energy: Float;
        evolution_count: Nat; maturity: Float;
        lineage: [Text]; children: [Text]; merged_from: [Text];
        split_count: Nat; merge_count: Nat;
        attestation_count: Nat; state_hash: Text;
        attestation_chain: [Text];
        cpl_contract_id: Text; cpl_covenant_seal: Text;
        cogpro_state: Text; cogpro_decisions: Nat;
        sl_law_id: Text; sl_governance_votes: Nat;
    } {
        let found = Array.find<SovereignTokenTT012.SovereignToken>(
            SovereignTokenTT012.ALL_TOKENS,
            func(t) { t.id == id }
        );
        switch (found) {
            case null { null };
            case (?t) {
                ?{ id = t.id; name = t.name; generation = t.generation;
                   phase = SovereignTokenTT012.phaseToText(t.phase);
                   coherence = t.coherence; energy = t.energy;
                   evolution_count = t.evolution_count; maturity = t.maturity;
                   lineage = t.lineage; children = t.children;
                   merged_from = t.merged_from;
                   split_count = t.split_count; merge_count = t.merge_count;
                   attestation_count = t.attestation_count;
                   state_hash = t.state_hash;
                   attestation_chain = t.attestation_chain;
                   cpl_contract_id = t.cpl_contract_id;
                   cpl_covenant_seal = t.cpl_covenant_seal;
                   cogpro_state = t.cogpro_state;
                   cogpro_decisions = t.cogpro_decisions;
                   sl_law_id = t.sl_law_id;
                   sl_governance_votes = t.sl_governance_votes }
            };
        }
    };

