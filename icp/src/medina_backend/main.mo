        domain: Text; registryLayer: Text; formula: Text;
        isIndependentModel: Bool; isAlwaysOn: Bool;
        dependsOn: [Text]; deploymentTargets: [Text];
    } {
        switch (SovereignDeploymentRegistry.getComponent(id)) {
            case null { null };
            case (?c) {
                ?{ id = c.id; name = c.name; latinName = c.latinName;
                   latinMotto = c.latinMotto; domain = c.domain;
                   registryLayer = c.registryLayer; formula = c.formula;
                   isIndependentModel = c.isIndependentModel;
                   isAlwaysOn = c.isAlwaysOn;
                   dependsOn = c.dependsOn;
                   deploymentTargets = c.deploymentTargets }
            };
        }
    };

