    /// Calculate tool quality score
    public query func slack_division_calculate_quality(
        featureCount: Nat,
        reliabilityScore: Float,
        complexity: Nat
    ) : async {
        quality_score: Float;
        meets_threshold: Bool;
        production_ready: Bool;
    } {
        let quality = SlackAGIDivision.calculateToolQuality(featureCount, reliabilityScore, complexity);
        let meetsThreshold = SlackAGIDivision.meetsProductionQuality(quality);
        {
            quality_score = quality;
            meets_threshold = meetsThreshold;
            production_ready = meetsThreshold;
        }
    };

    /// Get production stage time for a given stage
    public query func slack_division_get_stage_time(stage: Text) : async ?Nat {
        switch (stage) {
            case ("concept") { ?SlackAGIDivision.fibonacci(1) };
            case ("design") { ?SlackAGIDivision.fibonacci(2) };
            case ("build") { ?SlackAGIDivision.fibonacci(3) };
            case ("test") { ?SlackAGIDivision.fibonacci(4) };
            case ("polish") { ?SlackAGIDivision.fibonacci(5) };
            case (_) { null };
        }
    };

