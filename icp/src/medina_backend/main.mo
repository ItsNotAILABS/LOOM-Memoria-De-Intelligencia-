        let maxSteps = encStatus.rotation_max_steps;
        {
            tier_name = encStatus.rotation_tier;
            steps_in_tier = maxSteps;
            current_step = encStatus.rotation_step;
            progress_percent = if (maxSteps == 0) { 0.0 } else {
                Float.fromInt(encStatus.rotation_step) / Float.fromInt(maxSteps) * 100.0
            };
            coherence_required_for_e8 = IcosahedralLeechGeometry.COHERENCE_THRESHOLD_E8;
            coherence_required_for_leech = IcosahedralLeechGeometry.COHERENCE_THRESHOLD_LEECH;
        }
    };
    
    // ================================================================== //
    // THREE HEARTS INTELLIGENCE ROUTING API                                //
    // ================================================================== //
    //                                                                       //
    // This is the MASTER INTELLIGENCE ROUTING SYSTEM.                       //
    // ALL intelligence queries flow through the Three Hearts:               //
    //                                                                       //
    // Input → Heart3 (Orchestrate) → Heart2 (Couple) →                      //
    //         Heart1 (Compute) → Execute → Return with ANIMA hash           //
    //                                                                       //
    // ================================================================== //
    
    /// Intelligence Router State
    stable var intelligenceRouterState = IntelligenceRouter.init();
    
    /// Route intelligence query through Three Hearts
    /// This is the MAIN entry point for all intelligence operations
    public func threeHeartsRoute(
        query: Text,
        context: Text,
        source: Text,
        clusterTarget: Text,
        priority: Text
    ) : async {
        success: Bool;
        response_id: Text;
        content: Text;
        model_id: Text;
        coherence: Float;
        anima_hash: Text;
        heart_phases: {
            theta_metropolis: Float;
            theta_coupling: Float;
            theta_regulating: Float;
            global_coherence: Float;
        };
        execution_time_ns: Int;
    } {
        // Parse source
        let routeSource : IntelligenceRouter.RouteSource = switch (source) {
            case ("api") { #API };
            case ("internal") { #Internal };
            case ("scheduled") { #Scheduled };
            case ("heartbeat") { #Heartbeat };
            case ("cascade") { #Cascade };
            case (_) { #Internal };
        };
        
        // Parse cluster target
        let cluster : IntelligenceRouter.ClusterTarget = switch (clusterTarget) {
            case ("r_cluster") { #R_Cluster };
            case ("u_cluster") { #U_Cluster };
            case ("d_cluster") { #D_Cluster };
            case ("n_cluster") { #N_Cluster };
            case (_) { #Any };
        };
        
        // Parse priority
        let prio : ThreeHeartsIntelligence.Priority = switch (priority) {
            case ("critical") { #Critical };
            case ("high") { #High };
            case ("normal") { #Normal };
            case ("low") { #Low };
            case ("background") { #Background };
            case (_) { #Normal };
        };
        
        // Route through intelligence router
        let (newState, result) = IntelligenceRouter.route(
            intelligenceRouterState,
            query,
            context,
            routeSource,
            cluster,
            prio,
            sovereignState.oro.organism_state
        );
        intelligenceRouterState := newState;
        
        {
            success = result.success;
            response_id = result.response.response_id;
            content = result.response.content;
            model_id = result.response.model_id;
            coherence = result.response.coherence_at_execution;
            anima_hash = result.response.anima_hash;
            heart_phases = {
                theta_metropolis = result.response.heart_phases.theta_metropolis;
                theta_coupling = result.response.heart_phases.theta_coupling;
                theta_regulating = result.response.heart_phases.theta_regulating;
                global_coherence = result.response.heart_phases.global_coherence;
            };
            execution_time_ns = result.response.execution_time_ns;
        }
    };
    
