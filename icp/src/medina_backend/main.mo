    /// Validate request with edge gate coherence check
    public query func edgeGateCoherenceCheck(
        edgeSignature: Text,
        browserSignature: Text,
        timestamp: Int,
        nonce: Text,
        payload: Text
    ) : async EdgeGateStrategy.EdgeValidationResult {
        let sig : EdgeGateStrategy.RequestSignature = {
            edgeSignature = edgeSignature;
            browserSignature = browserSignature;
            timestamp = timestamp;
            nonce = nonce;
            proofOfWork = null;
        };
        EdgeGateStrategy.coherenceCheck(sig, payload)
    };

