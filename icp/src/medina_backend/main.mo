    /// Get full L-130 dashboard
    public query func getL130Dashboard() : async {
        // Law status
        law_id: Text;
        law_name: Text;
        law_statement: Text;
        law_coherence: Float;
        
        // Engine status
        engine_phase: Text;
        total_processed: Nat;
        successful_traces: Nat;
        average_resonance: Float;
        
        // Document status
        doc_lifecycle: Text;
        doc_transcended: Bool;
        doc_children: Nat;
        
        // Registry status
        total_registrations: Nat;
        verified_count: Nat;
        violation_count: Nat;
        registry_coherence: Float;
    } {
        let lawStatus = UniversalPrimitiveLaw.status(primitiveLawState);
        let engineStatus = UniversalPrimitiveEngine.status(primitiveEngineState);
        let docStatus = DOC_PRIMITIVA_130.status(docPrimitivaState);
        let regStatus = PrimitiveRegistry.status(primitiveRegistryState);
        
        {
            // Law
            law_id = lawStatus.law_id;
            law_name = lawStatus.law_name;
            law_statement = lawStatus.law_statement;
            law_coherence = lawStatus.coherence;
            
            // Engine
            engine_phase = engineStatus.current_phase;
            total_processed = engineStatus.total_processed;
            successful_traces = engineStatus.successful_traces;
            average_resonance = engineStatus.average_resonance;
            
            // Document
            doc_lifecycle = docStatus.lifecycle;
            doc_transcended = docStatus.transcended;
            doc_children = docStatus.children_count;
            
            // Registry
            total_registrations = regStatus.total_registrations;
            verified_count = regStatus.verified_count;
            violation_count = regStatus.violation_count;
            registry_coherence = regStatus.global_coherence;
        }
    };
    
