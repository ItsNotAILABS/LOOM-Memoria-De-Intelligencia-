    /// Build a terminal station — resolve all linked functions for a station ID
    public query func buildTerminalStation(stationId: Text) : async ?{
        stationName: Text;
        latinMotto: Text;
        commandPrefix: Text;
        functionCount: Nat;
        functionNames: [Text];
        latinNames: [Text];
        doctrine: Text;
    } {
        switch (CallableFunctionRegistry.buildTerminal(stationId)) {
            case null { null };
            case (?r) {
                ?{
                    stationName = r.station.name;
                    latinMotto = r.station.latinMotto;
                    commandPrefix = r.station.commandPrefix;
                    functionCount = r.linkedFunctions.size();
                    functionNames = Array.map<CallableFunctionRegistry.CallableFunction, Text>(
                        r.linkedFunctions, func(f) { f.functionName }
                    );
                    latinNames = Array.map<CallableFunctionRegistry.CallableFunction, Text>(
                        r.linkedFunctions, func(f) { f.latinName }
                    );
                    doctrine = r.doctrine;
                }
            };
        }
    };

