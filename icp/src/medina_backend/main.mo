    /// Invoke any build helper by type
    public query func invokeBuildHelper(helperType: Text, input: Text) : async Text {
        let hType = switch (helperType) {
            case ("PRIMIS" or "PrimitiveSolver") #PrimitiveSolver;
            case ("ARCHITECTUS" or "ArchitectureKeeper") #ArchitectureKeeper;
            case ("DISSOLUTIO" or "TechnologyDissolver") #TechnologyDissolver;
            case ("FORMULOR" or "FormulaCreator") #FormulaCreator;
            case ("VERITAS" or "TruthValidator") #TruthValidator;
            case (_) #TruthValidator;  // Default to VERITAS
        };
        SovereignBuildHelpers.invokeHelper(hType, input)
    };
    
