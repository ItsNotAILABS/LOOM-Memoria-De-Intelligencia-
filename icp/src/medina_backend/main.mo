    /// Process an entity through L-130 (all 4 phases)
    /// STRIP → DESCEND → VERIFY → RECOMPOSE
    public func traceToPrimitive(
        entityName: Text,
        category: Text,
        currentForm: Text,
        targetDepth: Nat
    ) : async {
        success: Bool;
        trace_id: ?Text;
        recomposition: Text;
        final_resonance: Float;
        phases_completed: Nat;
        errors: [Text];
    } {
        // Convert category string to type
        let cat : UniversalPrimitiveLaw.EntityCategory = switch (category) {
            case ("color") #Color;
            case ("document") #Document;
            case ("canister") #Canister;
            case ("workflow") #Workflow;
            case ("contract") #Contract;
            case ("model") #Model;
            case ("organ") #Organ;
            case ("function") #Function;
            case ("memory") #Memory;
            case ("symbol") #Symbol;
            case (_) #Function;  // Default
        };
        
        // Create processing request
        let request : UniversalPrimitiveEngine.ProcessingRequest = {
            entity_name = entityName;
            entity_category = cat;
            current_form = currentForm;
            target_depth = targetDepth;
            strictness = 0.8;  // 80% strictness
        };
        
        // Process through the engine
        let (newEngineState, newLawState, result) = UniversalPrimitiveEngine.process(
            primitiveEngineState,
            primitiveLawState,
            request
        );
        
        primitiveEngineState := newEngineState;
        primitiveLawState := newLawState;
        
        // If successful, register in the Primitive Registry
        switch (result.trace) {
            case (?trace) {
                let (newRegState, _) = PrimitiveRegistry.register(
                    primitiveRegistryState,
                    primitiveLawState,
                    entityName,
                    cat,
                    trace.trace_id
                );
                primitiveRegistryState := newRegState;
            };
            case null {};
        };
        
        {
            success = result.success;
            trace_id = switch (result.trace) { case (?t) ?t.trace_id; case null null };
            recomposition = result.recomposition;
            final_resonance = result.final_resonance;
            phases_completed = result.phases_completed;
            errors = result.errors;
        }
    };
    
    /// Check if entity has valid primitive trace (L-130 gate check)
    public func checkPrimitiveCompliance(entityName: Text) : async {
        allowed: Bool;
        status: ?Text;
        resonance: ?Float;
        reason: Text;
    } {
        let (newState, result) = PrimitiveRegistry.checkAccess(primitiveRegistryState, entityName);
        primitiveRegistryState := newState;
        {
            allowed = result.allowed;
            status = switch (result.status) { 
                case (?s) ?PrimitiveRegistry.statusToText(s); 
                case null null 
            };
            resonance = result.resonance;
            reason = result.reason;
        }
    };
    
