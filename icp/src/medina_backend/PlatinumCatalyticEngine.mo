    // ═══════════════════════════════════════════════════════════════════════════════════════════
    
    public type Branch = {
        id: Nat;
        name: Text;
        latin: Text;
        parent: ?Text;
        children: [Text];
        depth: Nat;
        
        // Branch-specific formula
        formula: Text;
        primitive_trace: Text;
        
        // Micro-level details
        micro_components: [MicroComponent];
        
        // Integration points
        integrations: [Text];
        
        // Always-on processes running on this branch
        active_processes: [ActiveProcess];
    };
    
    public type MicroComponent = {
        name: Text;
        scale: Text;           // femto, atto, quantum
        formula: Text;
        description: Text;
        primitive_trace: Text;
    };
    
    public type ActiveProcess = {
        id: Nat;
        name: Text;
        rate_hz: Float;        // Cycles per second
        is_running: Bool;      // Should always be true
        last_run: Int;
        total_runs: Nat;
    };

