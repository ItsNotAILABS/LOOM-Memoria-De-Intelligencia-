    // ENGINE STATE — ALWAYS-ON 24/7 RUNNING STATE
    // ═══════════════════════════════════════════════════════════════════════════════════════════
    
    public type EngineState = {
        #Running;      // Normal operation — SHOULD ALWAYS BE THIS
        #Accelerating; // Increasing catalytic rate
        #Peak;         // Maximum catalytic throughput
        #Regenerating; // Catalyst self-renewal (still running)
    };
    
    public type EngineMetrics = {
        /// Total catalytic cycles completed
        cycles_completed: Nat;
        
        /// Current turnover frequency (s⁻¹)
        current_tof: Float;
        
        /// Total molecules transformed
        molecules_transformed: Nat;
        
        /// Uptime in nanoseconds
        uptime_ns: Int;
        
        /// Start timestamp
        started_at: Int;
        
        /// Current state
        state: EngineState;
        
        /// Branch activity counts
        branch_activity: [(Text, Nat)];
        
        /// Energy efficiency (0-1)
        efficiency: Float;
        
        /// Last heartbeat
        last_heartbeat: Int;
    };

    // ═══════════════════════════════════════════════════════════════════════════════════════════
