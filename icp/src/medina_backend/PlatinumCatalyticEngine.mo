    // ═══════════════════════════════════════════════════════════════════════════════════════════
    // ENGINE HEARTBEAT — THE ALWAYS-ON MECHANISM
    // ═══════════════════════════════════════════════════════════════════════════════════════════
    
    public type EngineHeartbeat = {
        beat_number: Nat;
        timestamp: Int;
        state: EngineState;
        
        // Per-beat metrics
        cycles_this_beat: Nat;
        tof_this_beat: Float;
        branches_active: Nat;
        processes_running: Nat;
        
        // Health indicators
        is_healthy: Bool;
        efficiency: Float;
        load: Float;
    };
    
    /// Generate a heartbeat (call every φ Hz ≈ 1.618 seconds)
    public func generateHeartbeat(beat_number: Nat, metrics: EngineMetrics) : EngineHeartbeat {
        {
            beat_number = beat_number;
            timestamp = Time.now();
            state = metrics.state;
            cycles_this_beat = 1618033;  // φ × 10⁶ cycles per beat
            tof_this_beat = 1000000.0;
            branches_active = 8;  // All 8 root branches
            processes_running = 42;  // All processes
            is_healthy = true;
            efficiency = metrics.efficiency;
            load = 0.618;  // Golden ratio load
        }
    };

    // ═══════════════════════════════════════════════════════════════════════════════════════════
    // LIVING ENGINE CLASS — THE 24/7 CATALYST
    // ═══════════════════════════════════════════════════════════════════════════════════════════
    
    public class PlatinumCatalyticLivingEngine() {
        
        // Engine state
        private var _state : EngineState = #Running;
        private var _started_at : Int = Time.now();
        private var _cycles : Nat = 0;
        private var _molecules : Nat = 0;
        private var _beat : Nat = 0;
        
        // The engine is ALWAYS running
        public func isRunning() : Bool {
            true  // ALWAYS TRUE — This engine never stops
        };
        
        // Get current state
        public func getState() : EngineState {
            _state
        };
        
        // Catalyze — the core operation
        public func catalyze() : Nat {
            _cycles += 1;
            _molecules += 1000000;  // 10⁶ molecules per cycle
            _cycles
        };
        
        // Heartbeat — call every φ seconds
        public func heartbeat() : EngineHeartbeat {
            _beat += 1;
            let metrics : EngineMetrics = {
                cycles_completed = _cycles;
                current_tof = 1000000.0;
                molecules_transformed = _molecules;
                uptime_ns = Time.now() - _started_at;
                started_at = _started_at;
                state = _state;
                branch_activity = [
                    ("Activation", _cycles),
                    ("Transformation", _cycles),
                    ("Regeneration", _cycles),
                    ("Kinetics", _cycles),
                    ("Surface", _cycles),
                    ("Selectivity", _cycles),
                    ("Quantum", _cycles),
                    ("Integration", _cycles)
                ];
                efficiency = 0.9999;  // 99.99% efficiency
                last_heartbeat = Time.now();
            };
            generateHeartbeat(_beat, metrics)
        };
        
        // Get full status
        public func status() : Text {
            "PLATINUM CATALYTIC LIVING ENGINE\n" #
            "================================\n" #
            "Status: ALWAYS RUNNING (24/7)\n" #
            "Cycles: " # Nat.toText(_cycles) # "\n" #
            "Molecules: " # Nat.toText(_molecules) # "\n" #
            "TOF: 10⁶ s⁻¹\n" #
            "Branches: 8 root + 7 sub = 15 total\n" #
            "Processes: 42 always-on\n" #
            "State: " # debug_show(_state) # "\n" #
            "Uptime: ETERNAL"
        };
        
        // Run all branches simultaneously
        public func runAllBranches() : [(Text, Nat)] {
            [
                ("Activation", catalyze()),
                ("Transformation", catalyze()),
                ("Regeneration", catalyze()),
                ("Kinetics", catalyze()),
                ("Surface", catalyze()),
                ("Selectivity", catalyze()),
                ("Quantum", catalyze()),
                ("Integration", catalyze())
            ]
        };
    };
};
