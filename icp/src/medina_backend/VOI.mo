        layers.add({ number = 46; name = "State Management"; latinName = "Administratio Status"; domain = "VISIO_PRIMA"; technology = "Redux/MobX"; purpose = "State handling"; models = 8; primitivePath = ["State", "Store", "Action", "Reducer", "Dispatch"]; });
