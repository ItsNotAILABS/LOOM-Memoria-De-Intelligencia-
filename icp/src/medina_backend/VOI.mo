    // ═══════════════════════════════════════════════════════════════════════════════
    // FOUR SUB-OPERATING SYSTEMS
    // ═══════════════════════════════════════════════════════════════════════════════
    
    public type SubOperatingSystem = {
        id: Text;
        name: Text;
        latinName: Text;
        motto: Text;
        translation: Text;
        description: Text;
        layerRange: (Nat, Nat);  // Start layer to end layer
        totalModels: Nat;
        totalEngines: Nat;
        totalAgents: Nat;
        alwaysRunning: Bool;
    };
    
    /// 1. VISIO PRIMA — Frontend Intelligence
    public let VISIO_PRIMA : SubOperatingSystem = {
        id = "VOI-SUB-001";
        name = "VISIO PRIMA";
        latinName = "Visio Prima";
        motto = "Videre ante omnia";
        translation = "To see before all things";
        description = "Frontend Intelligence System - From glass display technology down to JavaScript/TypeScript execution. Every pixel, every button, every animation is intelligence.";
        layerRange = (1, 50);
        totalModels = 234;
