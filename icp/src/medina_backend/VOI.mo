        layers.add({ number = 145; name = "DMA Controller"; latinName = "Controller DMA"; domain = "FUNDAMENTUM_AETERNUM"; technology = "DMA"; purpose = "Direct memory"; models = 5; primitivePath = ["DMA", "Channel", "Descriptor", "Transfer", "Complete"]; });
        layers.add({ number = 146; name = "Interrupt Handler"; latinName = "Tractator Interrupti"; domain = "FUNDAMENTUM_AETERNUM"; technology = "Interrupt"; purpose = "Hardware interrupts"; models = 6; primitivePath = ["Interrupt", "Vector", "Handler", "Priority", "Ack"]; });
        layers.add({ number = 147; name = "Clock Source"; latinName = "Fons Horologii"; domain = "FUNDAMENTUM_AETERNUM"; technology = "Clock"; purpose = "Time source"; models = 5; primitivePath = ["Clock", "Tick", "Frequency", "PLL", "Crystal"]; });
        layers.add({ number = 148; name = "Power Management"; latinName = "Administratio Potentiae"; domain = "FUNDAMENTUM_AETERNUM"; technology = "Power"; purpose = "Power states"; models = 6; primitivePath = ["Power", "State", "Wake", "Sleep", "Voltage"]; });
        layers.add({ number = 149; name = "PHY Interface"; latinName = "Interfacies PHY"; domain = "FUNDAMENTUM_AETERNUM"; technology = "PHY"; purpose = "Physical layer"; models = 6; primitivePath = ["PHY", "Signal", "Modulate", "Encode", "Symbol"]; });
        layers.add({ number = 150; name = "Wire Interface"; latinName = "Interfacies Fili"; domain = "FUNDAMENTUM_AETERNUM"; technology = "Wire"; purpose = "Physical wire - the deepest layer"; models = 5; primitivePath = ["Wire", "Signal", "Voltage", "Current", "Electron"]; });
        
        Buffer.toArray(layers)
    };
    
    // ═══════════════════════════════════════════════════════════════════════════════
    // DECISION HASHING SYSTEM
    // Every 2 seconds, across all models, decisions are hashed
    // ═══════════════════════════════════════════════════════════════════════════════
    
    public type DecisionHash = {
        decisionId: Text;
        modelId: Text;
        layerNumber: Nat;
        timestamp: Int;
        inputHash: [Nat8];
        outputHash: [Nat8];
        contextHash: [Nat8];
        animaHash: [Nat8];
        tokensMinted: Nat;
        ipProtected: Bool;
    };
    
    /// Decision hashing interval (2 seconds)
    public let DECISION_HASH_INTERVAL_NS : Nat = 2_000_000_000;
    
    /// Create decision hash
    public func createDecisionHash(
        modelId: Text,
        layerNumber: Nat,
        input: Text,
        output: Text,
        context: Text
    ) : DecisionHash {
        let now = Time.now();
        let decisionId = modelId # "-" # Int.toText(now);
        
        {
            decisionId = decisionId;
            modelId = modelId;
            layerNumber = layerNumber;
            timestamp = now;
            inputHash = hashText(input);
            outputHash = hashText(output);
            contextHash = hashText(context);
            animaHash = hashText(decisionId # input # output);
            tokensMinted = 1;  // Every decision mints 1 proof token
            ipProtected = true;
        }
    };
    
    /// Simple hash function
    func hashText(text: Text) : [Nat8] {
        var h : Nat64 = 0x564F495F48415348;  // "VOI_HASH"
        for (c in text.chars()) {
            h := h +% Nat64.fromNat(Nat32.toNat(charToNat32(c)));
            h := h *% 1099511628211;
        };
        [
            Nat8.fromNat(Nat64.toNat((h >> 56) & 0xFF)),
            Nat8.fromNat(Nat64.toNat((h >> 48) & 0xFF)),
            Nat8.fromNat(Nat64.toNat((h >> 40) & 0xFF)),
            Nat8.fromNat(Nat64.toNat((h >> 32) & 0xFF)),
            Nat8.fromNat(Nat64.toNat((h >> 24) & 0xFF)),
            Nat8.fromNat(Nat64.toNat((h >> 16) & 0xFF)),
            Nat8.fromNat(Nat64.toNat((h >> 8) & 0xFF)),
            Nat8.fromNat(Nat64.toNat(h & 0xFF))
        ]
    };
    
    func charToNat32(c: Char) : Nat32 {
        Prim.charToNat32(c)
    };
    
    // ═══════════════════════════════════════════════════════════════════════════════
    // AGENT TIER SYSTEM
    // 600+ agents across Internal, Sovereign, Partner, Enterprise, Public
    // ═══════════════════════════════════════════════════════════════════════════════
    
    public type AgentTier = {
        #Internal;     // 100 agents × 3 uses = 300 uses
        #Sovereign;    // 100 agents × 3 uses = 300 uses
        #Partner;      // 100 agents × 2 uses = 200 uses
        #Enterprise;   // 100 agents × 2 uses = 200 uses
        #Public;       // 147 agents × 2 uses = 294 uses
        #OnCall;       // 100 purpose agents callable anytime
    };
    
    public type AgentSpec = {
        id: Text;
        name: Text;
        tier: AgentTier;
        uses: [Text];  // 2-3 uses per tier
        models: Nat;
        intelligence: Float;
        alwaysRunning: Bool;
    };
    
    /// Total agent count by tier
    public let AGENT_COUNTS = {
        internal = 100;
        sovereign = 100;
        partner = 100;
        enterprise = 100;
        public_ = 147;
        onCall = 100;
        total = 647;
    };
    
