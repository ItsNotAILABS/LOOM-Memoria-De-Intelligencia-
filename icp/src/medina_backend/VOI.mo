        layers.add({ number = 43; name = "Vue Runtime"; latinName = "Tempus Vue"; domain = "VISIO_PRIMA"; technology = "Vue"; purpose = "Vue execution"; models = 8; primitivePath = ["Vue", "Reactive", "Component", "Directive", "Watcher"]; });
        layers.add({ number = 44; name = "Svelte Runtime"; latinName = "Tempus Svelte"; domain = "VISIO_PRIMA"; technology = "Svelte"; purpose = "Svelte execution"; models = 7; primitivePath = ["Svelte", "Compile", "Reactive", "Store", "Transition"]; });
