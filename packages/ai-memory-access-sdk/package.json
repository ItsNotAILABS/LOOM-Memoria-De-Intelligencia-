{
  "name": "@medina/ai-memory-access-sdk",
  "version": "1.0.0",
  "description": "MEDINA AI Memory Access SDK — Protocol-compliant memory operations for AI agents. PROT-380+. Frequency-aligned, doctrine-bound, audit-logged.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "license": "ISIL-1.0",
  "private": true,
  "author": "Alfredo Freddy Medina Hernandez <medinasiftech@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/FreddyCreates/Medina-Memory-More-AI"
  },
  "keywords": [
    "medina",
    "memory-access",
    "ai-agents",
    "protocol",
    "prot-380",
    "sovereign",
    "token",
    "memory-temple",
    "frequency-aligned"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc && tsc -p tsconfig.esm.json",
    "build:watch": "tsc --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "crypto-js": "^4.1.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
