{
  "name": "@medina/memory-sdk",
  "version": "2.0.0",
  "description": "MEDINA Memory SDK — Sovereign memory temple, lineage tracking, phi-traced persistence. HIGHEST CONFIDENTIALITY.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "license": "ISIL-1.0",
  "private": true,
  "author": "Alfredo Freddy Medina Hernandez <medinasiftech@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/FreddyCreates/Medina-Memory-More-AI"
  },
  "keywords": [
    "medina",
    "memory",
    "sovereign",
    "intelligence",
    "phi-traced",
    "memory-temple",
    "lineage",
    "organism",
    "icp",
    "dfinity"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc && tsc -p tsconfig.esm.json",
    "build:watch": "tsc --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "@dfinity/agent": "^0.20.0",
    "@dfinity/candid": "^0.20.0",
    "@dfinity/principal": "^0.20.0"
