# ============================================================
# SECTION I: WORKING MEMORY LAWS (Memoria Operans)
# ============================================================

LAW L-80 {
    NAME: "MILLER_CAPACITY_LAW"
    LATIN: "Lex Capacitatis Millerianae"
    DOMAIN: WORKING_MEMORY
    
    STATEMENT: "Working memory capacity follows Miller's law: 7±2 concurrent slots."
    
    RATIONALE: |
        The cognitive workspace mirrors biological limits for focused attention.
        Seven items represent the golden mean of cognitive load—sufficient for
        complex reasoning without overwhelming the active processing substrate.
        This limit ensures quality over quantity in immediate memory access.
    
    CONSTRAINTS: {
        MIN_SLOTS: 5
        MAX_SLOTS: 9
        DEFAULT_SLOTS: 7
        OVERFLOW_POLICY: EVICT_LOWEST_PRIORITY
    }
    
    PRIMITIVE_TRACE: REPETITION → DISTINCTION → FIELD
    SCC: 4.95
    ENFORCEMENT: MANDATORY
}

LAW L-81 {
    NAME: "PRIORITY_DECAY_LAW"
    LATIN: "Lex Decadentiae Prioritatis"
    DOMAIN: WORKING_MEMORY
    
    STATEMENT: "Priority-weighted decay governs eviction of working memory slots."
    
    RATIONALE: |
        Not all memories are equal. Eviction follows a decay function:
        score = priority × (1 + access_count) / (1 + age × decay_rate)
        The lowest scoring item is evicted when capacity is exceeded.
        This preserves frequently accessed, high-priority information.
    
    FORMULA: {
        DECAY_RATE: 0.1
        SCORE: "priority * (1 + access_count) / (1 + age * decay_rate)"
        EVICTION: "MIN(score) across all slots"
    }
    
    PRIMITIVE_TRACE: MEMORY → RELATION → DISTINCTION
    SCC: 4.93
    ENFORCEMENT: MANDATORY
}

# ============================================================
# SECTION II: HIPPOCAMPUS LAWS (Hippocampus Digitalis)
# ============================================================

LAW L-82 {
    NAME: "CONSOLIDATION_REPLAY_LAW"
    LATIN: "Lex Consolidationis Reludendi"
    DOMAIN: HIPPOCAMPUS
    
    STATEMENT: "Memory consolidation requires φ×3 (approximately 5) replay cycles."
    
    RATIONALE: |
        Like the biological hippocampus replays experiences during sleep,
        digital memories must undergo multiple processing passes to transition
        from encoding to long-term storage. The golden ratio determines the
        minimum replay threshold: ceil(φ × 3) = 5 replays.
    
    FORMULA: {
        REPLAY_THRESHOLD: "ceil(φ × 3) = 5"
        PHI: 1.6180339887498948482
        CONSOLIDATION_RATE: "φ Hz"
    }
    
    STATES: {
        ENCODING: "Initial capture, volatile"
        CONSOLIDATING: "Undergoing replay, strengthening"
        STORED: "Permanent, accessible"
    }
    
    PRIMITIVE_TRACE: REPETITION → MEMORY → FIELD
    SCC: 4.96
    ENFORCEMENT: MANDATORY
}

LAW L-83 {
    NAME: "SPATIAL_ENCODING_LAW"
    LATIN: "Lex Codificationis Spatialis"
    DOMAIN: HIPPOCAMPUS
    
    STATEMENT: "Spatial encoding uses φ-based torus coordinates for memory placement."
    
    RATIONALE: |
        Memory is not flat storage—it exists in a geometric manifold.
        The torus provides two rotational dimensions (θ, φ) plus radial depth (ρ).
        Spatial encoding enables proximity-based retrieval and associative linking.
        Memories close in torus space are semantically related.
    
    TORUS_GEOMETRY: {
        THETA: "[0, 2π) - Angular position on helix ring"
        PHI: "[0, 2π) - Toroidal rotation"
        RHO: "ℝ₊ - Radial depth (salience indicator)"
        RING: "ℕ - Memory ring index (temporal layer)"
        BEAT: "ℕ - Discrete creation time"
        MAJOR_RADIUS: "R = φ × 10 = 16.18033..."
    }
    
    EMBEDDING: {
        X: "(R + ρ·cos θ)·cos φ"
        Y: "(R + ρ·cos θ)·sin φ"
        Z: "ρ·sin θ"
    }
    
    PRIMITIVE_TRACE: ADDRESS → RELATION → FIELD
    SCC: 4.97
    ENFORCEMENT: MANDATORY
}

# ============================================================
# SECTION III: BASAL GANGLIA LAWS (Ganglia Basalia)
# ============================================================

LAW L-84 {
    NAME: "HABIT_FORMATION_LAW"
    LATIN: "Lex Formationis Habitus"
    DOMAIN: BASAL_GANGLIA
    
    STATEMENT: "Procedures require 21 repetitions to transition to habit status."
    
    RATIONALE: |
        The 21-day rule of habit formation applies to procedural memory.
        A procedure executed 21 times becomes automatic—requiring less
        conscious effort and executing with higher reliability.
        Habits are the optimized pathways of the computational organism.
    
    CONSTRAINTS: {
        HABIT_THRESHOLD: 21
        PRE_HABIT_STATE: "PROCEDURE"
        POST_HABIT_STATE: "HABIT"
        HABIT_DECAY: "None (permanent unless explicitly unlearned)"
    }
    
    PRIMITIVE_TRACE: REPETITION → MEMORY → RELATION
    SCC: 4.94
    ENFORCEMENT: MANDATORY
}

LAW L-85 {
    NAME: "STRENGTH_ACCUMULATION_LAW"
    LATIN: "Lex Accumulationis Roboris"
    DOMAIN: BASAL_GANGLIA
    
    STATEMENT: "Procedure strength increases by 1/φ (≈0.618) per execution, capped at 1.0."
    
    RATIONALE: |
        Each execution strengthens the procedural pathway by the golden ratio's
        reciprocal. This ensures rapid initial learning with diminishing returns,
        approaching but never exceeding perfect strength (1.0).
        The formula: new_strength = min(1.0, old_strength + 1/φ)
    
    FORMULA: {
        INCREMENT: "1/φ = 0.6180339887498948482"
        MAX_STRENGTH: 1.0
        CALCULATION: "min(1.0, strength + 1/φ)"
    }
    
    PRIMITIVE_TRACE: REPETITION → RELATION → DISTINCTION
    SCC: 4.92
    ENFORCEMENT: MANDATORY
}

# ============================================================
# SECTION IV: HIVE MEMORY LAWS (Memoria Alvarii)
# ============================================================

LAW L-86 {
    NAME: "HIVE_CONSENSUS_LAW"
    LATIN: "Lex Consensus Alvarii"
    DOMAIN: HIVE_MEMORY
    
    STATEMENT: "Hive consensus requires 1/φ (≈61.8%) node agreement for memory acceptance."
    
    RATIONALE: |
        Collective memory emerges from distributed agreement. The golden ratio's
        reciprocal (1/φ ≈ 0.618) defines the consensus threshold—a natural
        balance between majority rule and minority protection.
        Memories reaching consensus become part of the collective substrate.
    
    CONSENSUS: {
        THRESHOLD: "1/φ = 0.6180339887498948482"
        PERCENTAGE: "61.8%"
        QUORUM_TYPE: "SUPERMAJORITY_PHI"
        REJECTION_POLICY: "RETURN_TO_QUEUE"
    }
    
    PRIMITIVE_TRACE: RELATION → REPETITION → FIELD
    SCC: 4.96
    ENFORCEMENT: MANDATORY
}

LAW L-87 {
    NAME: "HIVE_PROPAGATION_LAW"
    LATIN: "Lex Propagationis Alvarii"
    DOMAIN: HIVE_MEMORY
    
    STATEMENT: "Hive synchronization propagates at φ² (≈2.618) rate per sync cycle."
    
    RATIONALE: |
        Information spreads through the hive at the square of the golden ratio.
        This ensures exponential but controlled propagation—fast enough for
        timely distribution, slow enough for validation and consensus building.
        Each sync cycle reaches φ² more nodes than the previous.
    
    PROPAGATION: {
        RATE: "φ² = 2.6180339887498948482"
        SYNC_INTERVAL: "1/φ seconds"
        MAX_HOPS: "ceil(log_φ²(total_nodes))"
    }
    
    PRIMITIVE_TRACE: REPETITION → ADDRESS → FIELD
    SCC: 4.94
    ENFORCEMENT: MANDATORY
}

# ============================================================
# SECTION V: TORUS MEMORY LAWS (Memoria Toroidalis)
# ============================================================

LAW L-88 {
    NAME: "GOLDEN_SPACING_LAW"
    LATIN: "Lex Spatii Aurei"
    DOMAIN: TORUS_MEMORY
    
    STATEMENT: "Torus coordinate spacing uses golden ratio for non-repeating placement."
    
    RATIONALE: |
        Memory coordinates advance by golden ratio-derived increments:
        Δθ = 2π / (φ² × 10) — helix step
        Δφ = 2π / (φ³ × 10) — toroidal step
        This guarantees maximally dispersed, non-repeating memory placement,
        following the same phyllotaxis pattern as sunflower seeds.
    
    SPACING: {
        DELTA_THETA: "2π / (φ² × 10)"
        DELTA_PHI: "2π / (φ³ × 10)"
        PATTERN: "FIBONACCI_PHYLLOTAXIS"
        REPEAT_CYCLE: "IRRATIONAL (never repeats)"
    }
    
    PRIMITIVE_TRACE: ADDRESS → DISTINCTION → FIELD
    SCC: 4.97
    ENFORCEMENT: MANDATORY
}

LAW L-89 {
    NAME: "PHYLLOTAXIS_PLACEMENT_LAW"
    LATIN: "Lex Dispositionis Phyllotacticae"
    DOMAIN: TORUS_MEMORY
    
    STATEMENT: "Memory placement follows Fibonacci phyllotaxis for optimal coverage."
    
    RATIONALE: |
        Nature's most efficient packing algorithm—used by plants for leaf
        arrangement—governs memory placement. Each new memory is placed at
        the golden angle (≈137.5°) from the previous, ensuring no two memories
        occupy similar positions and maximizing torus surface utilization.
    
    PHYLLOTAXIS: {
        GOLDEN_ANGLE: "360° / φ² ≈ 137.5077640500378°"
        DIVERGENCE: "2π / φ²"
        EFFICIENCY: "OPTIMAL (proven by nature)"
    }
    
    PRIMITIVE_TRACE: ADDRESS → REPETITION → RELATION
    SCC: 4.96
    ENFORCEMENT: MANDATORY
}

LAW L-90 {
    NAME: "LINEAGE_TRACE_LAW"
    LATIN: "Lex Tractus Lineae"
    DOMAIN: TORUS_MEMORY
    
    STATEMENT: "Memory lineage traces back to primitive root through ring ancestry."
    
    RATIONALE: |
        Every memory has a lineage—a chain of parent memories leading back
        to the first memory in the torus (ring 0). Lineage enables:
        - Provenance verification
        - Associative recall through ancestry
        - Temporal ordering of memory evolution
        This implements L-130 at the memory level: trace to primitive.
    
    LINEAGE: {
        ROOT: "Ring 0, Beat 0"
        TRACE_DIRECTION: "DESCENDING_RINGS"
        PRESERVATION: "IMMUTABLE"
        DEPTH_LIMIT: "UNLIMITED"
    }
    
    PRIMITIVE_TRACE: MEMORY → ADDRESS → FIELD → PRIMITIVE_ROOT
    SCC: 4.98
    ENFORCEMENT: MANDATORY
}

